{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "vision-builder-dev",
  "permission": {
    "external_directory": {
      "~/workspace/**": "allow"
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.6:35b": {
          "name": "Qwen3.6 35B"
        },
        "deepseek-r1:32b": {
          "name": "DeepSeek-R1 32B"
        },
        "nomic-embed-text": {
          "name": "Nomic Embed Text"
        },
        "gemma4:31b": {
          "name": "Gemma 4 31B"
        }
      }
    }
  }
}
